def run_doctor(args: argparse.Namespace) -> int:
    results: list[CheckResult] = []

    codex_home = Path(args.codex_home).expanduser()
    home_config_path = Path(args.home_config).expanduser()

    ok, message = check_command("codex")
    add_result(results, PASS if ok else FAIL, "codex_cli", message)

    ok, message = check_command("git")
    add_result(results, PASS if ok else FAIL, "git_cli", message)

    if sys.platform == "darwin":
        ok, message = check_command("launchctl")
        add_result(results, PASS if ok else WARN, "service_manager", message if ok else "launchctl is not available; macOS service mode will be unavailable.")
    elif sys.platform.startswith("linux"):
        ok, message = check_command("systemctl")
        add_result(results, PASS if ok else WARN, "service_manager", message if ok else "systemctl is not available; Linux service mode will be unavailable.")

    home_config = None
    if home_config_path.exists():
        try:
            home_config = load_toml(home_config_path)
            add_result(results, PASS, "home_config", f"Continuum home config found at {home_config_path}.")
        except Exception as exc:
            add_result(results, FAIL, "home_config", f"Could not parse {home_config_path}: {exc}")
    else:
        add_result(results, WARN, "home_config", f"Continuum home config not found at {home_config_path}.")

    runner_root, runner_source = detect_runner_root(args, home_config if isinstance(home_config, dict) else None)
    if runner_root is None:
        add_result(results, FAIL, "runner_root", "Could not determine the runner root. Set CONTINUUM_RUNNER_ROOT, create ~/.config/continuum/config.toml, or pass --runner-root.")
    else:
        resolved = runner_root.resolve(strict=False)
        if runner_root.exists() or runner_root.is_symlink():
            add_result(results, PASS, "runner_root", f"Runner root resolved from {runner_source}: {runner_root} -> {resolved}")
        else:
            add_result(results, FAIL, "runner_root", f"Runner root resolved from {runner_source}, but the path does not exist: {runner_root}")

    codex_config_path = codex_home / "config.toml"
    codex_config: dict[str, Any] | None = None
    if codex_config_path.exists():
        try:
            codex_config = load_toml(codex_config_path)
            add_result(results, PASS, "codex_config", f"Codex config found at {codex_config_path}.")
        except Exception as exc:
            add_result(results, FAIL, "codex_config", f"Could not parse {codex_config_path}: {exc}")
    else:
        add_result(results, FAIL, "codex_config", f"Missing Codex config at {codex_config_path}.")

    global_agents = codex_home / "AGENTS.md"
    if global_agents.exists():
        agents_text = global_agents.read_text(encoding="utf-8", errors="replace")
        if file_contains_status_protocol(agents_text):
            add_result(results, WARN, "global_agents", "Global ~/.codex/AGENTS.md contains the STATUS protocol. Keep that protocol repo-local unless you want it in every interactive session.")
        else:
            add_result(results, PASS, "global_agents", f"Global AGENTS file found at {global_agents}.")
    else:
        add_result(results, WARN, "global_agents", f"Global AGENTS file not found at {global_agents}.")

    auth_path = codex_home / "auth.json"
    if auth_path.exists():
        status, message = auth_summary(auth_path)
        add_result(results, status, "codex_auth", message)
    else:
        add_result(results, FAIL, "codex_auth", f"Missing Codex auth file at {auth_path}.")

    hooks_path = codex_home / "hooks.json"
    if hooks_path.exists():
        hooks_text = hooks_path.read_text(encoding="utf-8", errors="replace")
        if "auto_continue.py" in hooks_text:
            add_result(results, WARN, "hooks", "Interactive Stop hook references auto_continue.py. The supervisor path does not need it, and it can add noise to normal interactive sessions.")
        else:
            add_result(results, PASS, "hooks", f"Hooks file found at {hooks_path}.")
    else:
        add_result(results, PASS, "hooks", "No global hooks.json file detected.")

    if codex_config:
        autonomous = lookup_path(codex_config, "profiles", "autonomous") or {}
        autonomous_network = lookup_path(codex_config, "profiles", "autonomous", "sandbox_workspace_write", "network_access")
        if (
            isinstance(autonomous, dict)
            and autonomous.get("approval_policy") == "never"
            and autonomous.get("sandbox_mode") == "workspace-write"
            and autonomous_network is False
        ):
            add_result(results, PASS, "autonomous_profile", "Autonomous profile is configured for unattended workspace-write runs.")
        else:
            add_result(results, WARN, "autonomous_profile", "Autonomous profile is missing or does not match the expected unattended settings (`approval_policy = never`, `sandbox_mode = workspace-write`, `network_access = false`).")

        autonomous_fast = lookup_path(codex_config, "profiles", "autonomous_fast") or {}
        autonomous_fast_network = lookup_path(codex_config, "profiles", "autonomous_fast", "sandbox_workspace_write", "network_access")
        if (
            isinstance(autonomous_fast, dict)
            and autonomous_fast.get("approval_policy") == "never"
            and autonomous_fast.get("sandbox_mode") == "workspace-write"
            and autonomous_fast_network is False
        ):
            add_result(results, PASS, "autonomous_fast_profile", "Autonomous fast profile is configured.")
        else:
            add_result(results, WARN, "autonomous_fast_profile", "Autonomous fast profile is missing or does not match the expected unattended settings.")

    rules_path = codex_home / "rules" / "default.rules"
    if rules_path.exists():
        rules_text = rules_path.read_text(encoding="utf-8", errors="replace")
        missing_rules = [command for command in ("add", "commit", "push") if not has_git_rule(rules_text, command)]
        if missing_rules:
            add_result(results, WARN, "git_rules", f"Git allow-rules are missing for: {', '.join(missing_rules)}.")
        else:
            add_result(results, PASS, "git_rules", "Git allow-rules exist for add, commit, and push.")
    else:
        add_result(results, WARN, "git_rules", f"Git rules file not found at {rules_path}.")

    if runner_root and (runner_root.exists() or runner_root.is_symlink()):
        required_files = [
            "codex_supervisor.py",
            "continuum_notify.py",
            "enable_project.py",
            "force_restart_project.sh",
            "force_stop_project.sh",
            "launch_project.sh",
            "pause_project.sh",
            "restart_project.sh",
            "stop_project.sh",
            "projects.json",
        ]
        missing = [name for name in required_files if not (runner_root / name).exists()]
        if missing:
            add_result(results, FAIL, "runner_files", f"Runner root is missing required files: {', '.join(missing)}.")
        else:
            add_result(results, PASS, "runner_files", "Runner root contains the expected supervisor files and projects.json.")

        service_runner = runner_root / "service_runner.py"
        if service_runner.exists():
            add_result(results, PASS, "service_runner", "Runner root includes service_runner.py for launchctl/systemd service mode.")
        else:
            add_result(results, WARN, "service_runner", "Runner root is missing service_runner.py. Run `continuum init` again to add service mode support.")

        projects_json_path = runner_root / "projects.json"
        projects_payload: dict[str, Any] | None = None
        if projects_json_path.exists():
            try:
                projects_payload = load_json(projects_json_path)
                projects = projects_payload.get("projects", [])
                if not isinstance(projects, list):
                    raise ValueError("'projects' must be a list")
                enabled_count = sum(1 for item in projects if isinstance(item, dict) and item.get("enabled", True))
                add_result(results, PASS, "projects_json", f"projects.json parsed successfully ({len(projects)} projects, {enabled_count} enabled).")
            except Exception as exc:
                add_result(results, FAIL, "projects_json", f"Could not parse {projects_json_path}: {exc}")
                projects_payload = None
        else:
            add_result(results, FAIL, "projects_json", f"Missing projects.json at {projects_json_path}.")
            projects_payload = None

        if isinstance(projects_payload, dict):
            configured_projects = projects_payload.get("projects", [])
            if not configured_projects:
                add_result(results, WARN, "projects", "No projects are configured in projects.json yet.")
            project_trust = lookup_path(codex_config or {}, "projects") if codex_config else {}

            for item in configured_projects:
                if not isinstance(item, dict):
                    add_result(results, FAIL, "project_entry", "projects.json contains a non-object project entry.")
                    continue

                name = str(item.get("name", "<unnamed>"))
                project_path_raw = item.get("path")
                if not isinstance(project_path_raw, str) or not project_path_raw.strip():
                    add_result(results, FAIL, f"project:{name}", f"{name}: missing project path.")
                    continue

                project_path = Path(project_path_raw).expanduser()
                if project_path.exists():
                    add_result(results, PASS, f"project:{name}:path", f"{name}: project path exists at {project_path}.")
                else:
                    add_result(results, FAIL, f"project:{name}:path", f"{name}: project path does not exist: {project_path}.")
                    continue

                if check_git_repo(project_path):
                    add_result(results, PASS, f"project:{name}:git", f"{name}: project path is a git repo.")
                else:
                    add_result(results, FAIL, f"project:{name}:git", f"{name}: project path is not a valid git repo.")

                agents_path = project_path / "AGENTS.md"
                if agents_path.exists():
                    text = agents_path.read_text(encoding="utf-8", errors="replace")
                    if file_contains_status_protocol(text):
                        if file_contains_managed_block(text):
                            add_result(results, PASS, f"project:{name}:agents", f"{name}: AGENTS.md contains a managed autonomous block and the STATUS protocol.")
                        else:
                            add_result(results, PASS, f"project:{name}:agents", f"{name}: AGENTS.md contains the STATUS protocol.")
                    else:
                        add_result(results, FAIL, f"project:{name}:agents", f"{name}: AGENTS.md exists but does not contain the required STATUS protocol.")
                else:
                    add_result(results, FAIL, f"project:{name}:agents", f"{name}: missing repo AGENTS.md.")

                progress_path = project_path / "docs" / "codex-progress.md"
                if progress_path.exists():
                    add_result(results, PASS, f"project:{name}:progress", f"{name}: progress log found at {progress_path}.")
                else:
                    add_result(results, WARN, f"project:{name}:progress", f"{name}: default progress log not found at {progress_path}.")

                trust_level = None
                if isinstance(project_trust, dict):
                    trust_level = lookup_path(project_trust, str(project_path), "trust_level")
                    if trust_level is None:
                        trust_level = lookup_path(project_trust, str(project_path.resolve()), "trust_level")
                if trust_level == "trusted":
                    add_result(results, PASS, f"project:{name}:trust", f"{name}: repo is marked trusted in ~/.codex/config.toml.")
                else:
                    add_result(results, WARN, f"project:{name}:trust", f"{name}: repo is not marked trusted in ~/.codex/config.toml. Project-scoped .codex settings may be ignored.")

    pass_count = sum(1 for item in results if item.status == PASS)
    warn_count = sum(1 for item in results if item.status == WARN)
    fail_count = sum(1 for item in results if item.status == FAIL)

    if args.json:
        payload = {
            "summary": {"pass": pass_count, "warn": warn_count, "fail": fail_count},
            "results": [item.__dict__ for item in results],
        }
        print(json.dumps(payload, indent=2))
    else:
        print("Continuum doctor")
        print()
        for item in results:
            print(f"[{item.status}] {item.message}")
        print()
        print(f"Summary: {pass_count} pass, {warn_count} warn, {fail_count} fail")

    return 1 if fail_count else 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="continuum", description="Continuum for Codex command line tools.")
    subparsers = parser.add_subparsers(dest="command")

    init = subparsers.add_parser("init", help="Create or refresh a local Continuum runner and home config.")
    init.add_argument("--runner-root", help="Runner directory to create or refresh. Defaults to the configured or home runner path.")
    init.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    init.add_argument("--home-runner-link", default=DEFAULT_HOME_RUNNER, help="Home-level runner path or symlink.")
    init.add_argument("--force", action="store_true", help="Overwrite copied runner scripts and refresh home config if it differs.")

    enable = subparsers.add_parser("enable", help="Enable a repo for autonomous Continuum runs.")
    enable.add_argument("project_path", help="Absolute or relative path to the target git repo.")
    enable.add_argument("--goal", required=True, help="Long-term project goal.")
    enable.add_argument("--name", help="Project name for logs and status output.")
    enable.add_argument("--profile", default="autonomous", help="Runner profile name.")
    enable.add_argument("--review", action="append", default=[], metavar="PATH", help="Repo-relative doc to review before choosing the next task. Repeatable.")
    enable.add_argument("--progress-path", default="docs/codex-progress.md", help="Repo-relative progress log path.")
    enable.add_argument("--runner-root", help="Runner root to use.")
    enable.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    enable.add_argument("--config", help="Explicit path to projects.json.")

    start = subparsers.add_parser("start", help="Launch one enabled project.")
    start.add_argument("project_name", help="Project name from projects.json.")
    start.add_argument("--runner-root", help="Runner root to use.")
    start.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    start.add_argument("--config", help="Explicit path to projects.json.")

    stop = subparsers.add_parser("stop", help="Request a clean stop for one project.")
    stop.add_argument("project_name", help="Project name from projects.json.")
    stop.add_argument("--runner-root", help="Runner root to use.")
    stop.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")

    restart = subparsers.add_parser("restart", help="Request a clean restart for one project.")
    restart.add_argument("project_name", help="Project name from projects.json.")
    restart.add_argument("--runner-root", help="Runner root to use.")
    restart.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    restart.add_argument("--config", help="Explicit path to projects.json.")

    pause = subparsers.add_parser("pause", help="Pause one project after the current pass finishes.")
    pause.add_argument("project_name", help="Project name from projects.json.")
    pause.add_argument("--runner-root", help="Runner root to use.")
    pause.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")

    force_stop = subparsers.add_parser("force-stop", help="Immediately kill one running detached project.")
    force_stop.add_argument("project_name", help="Project name from projects.json.")
    force_stop.add_argument("--runner-root", help="Runner root to use.")
    force_stop.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    force_stop.add_argument("--config", help="Explicit path to projects.json.")

    force_restart = subparsers.add_parser("force-restart", help="Immediately kill and relaunch one detached project.")
    force_restart.add_argument("project_name", help="Project name from projects.json.")
    force_restart.add_argument("--runner-root", help="Runner root to use.")
    force_restart.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    force_restart.add_argument("--config", help="Explicit path to projects.json.")

    service = subparsers.add_parser("service", help="Manage launchctl or systemd service mode.")
    service_subparsers = service.add_subparsers(dest="service_command")

    service_install = service_subparsers.add_parser("install", help="Install the service definition for one project.")
    service_install.add_argument("project_name", help="Project name from projects.json.")
    service_install.add_argument("--runner-root", help="Runner root to use.")
    service_install.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    service_install.add_argument("--config", help="Explicit path to projects.json.")
    service_install.add_argument("--service-dir", help="Override the service definition directory.")
    service_install.add_argument("--no-manager", action="store_true", help="Only write the service definition; do not call launchctl or systemctl.")

    service_uninstall = service_subparsers.add_parser("uninstall", help="Remove the service definition for one project.")
    service_uninstall.add_argument("project_name", help="Project name from projects.json.")
    service_uninstall.add_argument("--runner-root", help="Runner root to use.")
    service_uninstall.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    service_uninstall.add_argument("--config", help="Explicit path to projects.json.")
    service_uninstall.add_argument("--service-dir", help="Override the service definition directory.")
    service_uninstall.add_argument("--no-manager", action="store_true", help="Only remove the service definition file; do not call launchctl or systemctl.")

    service_start = service_subparsers.add_parser("start", help="Start one project through launchctl or systemd.")
    service_start.add_argument("project_name", help="Project name from projects.json.")
    service_start.add_argument("--runner-root", help="Runner root to use.")
    service_start.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    service_start.add_argument("--config", help="Explicit path to projects.json.")
    service_start.add_argument("--service-dir", help="Override the service definition directory.")

    service_stop = service_subparsers.add_parser("stop", help="Stop one project through launchctl or systemd.")
    service_stop.add_argument("project_name", help="Project name from projects.json.")
    service_stop.add_argument("--runner-root", help="Runner root to use.")
    service_stop.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    service_stop.add_argument("--config", help="Explicit path to projects.json.")
    service_stop.add_argument("--service-dir", help="Override the service definition directory.")

    service_restart = service_subparsers.add_parser("restart", help="Restart one project through launchctl or systemd.")
    service_restart.add_argument("project_name", help="Project name from projects.json.")
    service_restart.add_argument("--runner-root", help="Runner root to use.")
    service_restart.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    service_restart.add_argument("--config", help="Explicit path to projects.json.")
    service_restart.add_argument("--service-dir", help="Override the service definition directory.")

    service_status = service_subparsers.add_parser("status", help="Show launchctl or systemd status for one or all projects.")
    service_status.add_argument("project_name", nargs="?", help="Optional single project name to inspect.")
    service_status.add_argument("--runner-root", help="Runner root to use.")
    service_status.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    service_status.add_argument("--config", help="Explicit path to projects.json.")
    service_status.add_argument("--service-dir", help="Override the service definition directory.")
    service_status.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")

    status = subparsers.add_parser("status", help="Show project status from the runner state files.")
    status.add_argument("project_name", nargs="?", help="Optional single project name to inspect.")
    status.add_argument("--runner-root", help="Runner root to use.")
    status.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    status.add_argument("--config", help="Explicit path to projects.json.")
    status.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")

    doctor = subparsers.add_parser("doctor", help="Validate a local Continuum and Codex setup.")
    doctor.add_argument("--runner-root", help="Explicit runner root to inspect.")
    doctor.add_argument("--home-config", default=HOME_CONFIG_DEFAULT, help="Path to ~/.config/continuum/config.toml.")
    doctor.add_argument("--codex-home", default=CODEX_HOME_DEFAULT, help="Path to the Codex home directory.")
    doctor.add_argument("--json", action="store_true", help="Emit machine-readable JSON instead of human-readable text.")

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.command == "init":
        return run_init(args)
    if args.command == "enable":
        return run_enable(args)
    if args.command == "start":
        return run_start(args)
    if args.command == "stop":
        return run_stop(args)
    if args.command == "restart":
        return run_restart(args)
    if args.command == "pause":
        return run_pause(args)
    if args.command == "force-stop":
        return run_force_stop(args)
    if args.command == "force-restart":
        return run_force_restart(args)
    if args.command == "service":
        if args.service_command == "install":
            return run_service_install(args)
        if args.service_command == "uninstall":
            return run_service_uninstall(args)
        if args.service_command == "start":
            return run_service_start(args)
        if args.service_command == "stop":
            return run_service_stop(args)
        if args.service_command == "restart":
            return run_service_restart(args)
        if args.service_command == "status":
            return run_service_status(args)
        parser.parse_args(["service", "--help"])
        return 0
    if args.command == "status":
        return run_status(args)
    if args.command == "doctor":
        return run_doctor(args)

    parser.print_help()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
