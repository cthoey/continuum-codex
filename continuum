@dataclass
class CheckResult:
    status: str
    key: str
    message: str


def strip_toml_comment(line: str) -> str:
    in_string = False
    escaped = False
    result: list[str] = []
    for char in line:
        if char == '"' and not escaped:
            in_string = not in_string
        if char == "#" and not in_string:
            break
        result.append(char)
        escaped = (char == "\\") and not escaped
        if char != "\\":
            escaped = False
    return "".join(result).strip()


def split_toml_path(raw: str) -> list[str]:
    parts: list[str] = []
    current: list[str] = []
    in_string = False
    escaped = False
    for char in raw:
        if char == '"' and not escaped:
            in_string = not in_string
            continue
        if char == "." and not in_string:
            part = "".join(current).strip()
            if part:
                parts.append(part)
            current = []
            escaped = False
            continue
        current.append(char)
        escaped = (char == "\\") and not escaped
        if char != "\\":
            escaped = False
    tail = "".join(current).strip()
    if tail:
        parts.append(tail)
    return parts


def parse_toml_value(raw: str) -> Any:
    value = raw.strip()
    if not value:
        return ""
    if value.startswith('"') and value.endswith('"'):
        inner = value[1:-1]
        return bytes(inner, "utf-8").decode("unicode_escape")
    if value in {"true", "false"}:
        return value == "true"
    if re.fullmatch(r"[+-]?\d+", value):
        return int(value)
    return value


def load_toml(path: Path) -> dict[str, Any]:
    text = path.read_text(encoding="utf-8")
    try:
        import tomllib  # type: ignore

        return tomllib.loads(text)
    except Exception:
        data: dict[str, Any] = {}
        section_path: list[str] = []
        for raw_line in text.splitlines():
            line = strip_toml_comment(raw_line)
            if not line:
                continue
            if line.startswith("[") and line.endswith("]"):
                section_path = split_toml_path(line[1:-1].strip())
                continue
            if "=" not in line:
                continue
            key, raw_value = line.split("=", 1)
            key = key.strip().strip('"')
            value = parse_toml_value(raw_value)
            node = data
            for part in section_path:
                node = node.setdefault(part, {})
            node[key] = value
        return data


def load_json(path: Path) -> Any:
    return json.loads(path.read_text(encoding="utf-8"))


def lookup_path(data: dict[str, Any], *parts: str) -> Any:
    node: Any = data
    for part in parts:
        if not isinstance(node, dict) or part not in node:
            return None
        node = node[part]
    return node


def add_result(results: list[CheckResult], status: str, key: str, message: str) -> None:
    results.append(CheckResult(status=status, key=key, message=message))


def decode_jwt_payload(token: str) -> dict[str, Any] | None:
    try:
        segments = token.split(".")
        if len(segments) < 2:
            return None
        payload = segments[1]
        payload += "=" * ((4 - len(payload) % 4) % 4)
        decoded = base64.urlsafe_b64decode(payload.encode("utf-8"))
        return json.loads(decoded.decode("utf-8"))
    except Exception:
        return None


def format_timestamp(raw: str | None) -> str | None:
    if not raw:
        return None
    try:
        dt = datetime.fromisoformat(raw.replace("Z", "+00:00"))
        return dt.astimezone(timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")
    except Exception:
        return raw


def detect_runner_root(args: argparse.Namespace, home_config: dict[str, Any] | None) -> tuple[Path | None, str]:
    if args.runner_root:
        return Path(args.runner_root).expanduser(), "--runner-root"

    for env_name in ("CONTINUUM_RUNNER_ROOT", "RELAY_RUNNER_ROOT", "CODEX_RUNNER_ROOT"):
        value = os.environ.get(env_name)
        if value:
            return Path(value).expanduser(), f"${env_name}"

    if home_config:
        runner_root = home_config.get("runner_root")
        if isinstance(runner_root, str) and runner_root.strip():
            return Path(runner_root).expanduser(), args.home_config

    default_path = Path(DEFAULT_HOME_RUNNER).expanduser()
    if default_path.exists() or default_path.is_symlink():
        return default_path, "default"

    return None, "unresolved"


def check_command(binary: str) -> tuple[bool, str]:
    path = shutil.which(binary)
    if not path:
        return False, f"{binary} not found on PATH"
    try:
        completed = subprocess.run(
            [binary, "--version"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            check=False,
        )
        lines = [line.strip() for line in completed.stdout.splitlines() if line.strip()]
        preferred = [line for line in lines if not line.lower().startswith("warning:")]
        version = preferred[-1] if preferred else (lines[-1] if lines else "version unknown")
        return True, f"{binary} found at {path} ({version})"
    except Exception:
        return True, f"{binary} found at {path}"


def check_git_repo(path: Path) -> bool:
    try:
        completed = subprocess.run(
            ["git", "-C", str(path), "rev-parse", "--is-inside-work-tree"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return False
    return completed.returncode == 0 and completed.stdout.strip() == "true"


def has_git_rule(text: str, command: str) -> bool:
    pattern = re.compile(
        rf'prefix_rule\(\s*pattern=\["git",\s*"{re.escape(command)}"(?:,\s*".*?")*\],\s*decision="allow"\s*\)'
    )
    return bool(pattern.search(text))


def file_contains_status_protocol(text: str) -> bool:
    required = ("STATUS: CONTINUE", "STATUS: DONE", "STATUS: BLOCKED")
    return all(item in text for item in required)


def file_contains_managed_block(text: str) -> bool:
    return any(begin in text and end in text for begin, end in MANAGED_MARKERS)


def auth_summary(auth_path: Path) -> tuple[str, str]:
    try:
        auth = load_json(auth_path)
    except Exception as exc:
        return FAIL, f"Could not parse {auth_path}: {exc}"

    api_key = auth.get("OPENAI_API_KEY")
    if isinstance(api_key, str) and api_key.strip():
        return PASS, "API key auth is configured in ~/.codex/auth.json."

    tokens = auth.get("tokens")
    if isinstance(tokens, dict):
        access_token = tokens.get("access_token")
        refresh_token = tokens.get("refresh_token")
        payload = decode_jwt_payload(access_token) if isinstance(access_token, str) else None
        expiry = None
        if isinstance(payload, dict) and isinstance(payload.get("exp"), int):
            expiry = datetime.fromtimestamp(payload["exp"], tz=timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")
        last_refresh = format_timestamp(auth.get("last_refresh"))
        detail_bits = ["Saved Codex auth tokens are present."]
        if last_refresh:
            detail_bits.append(f"Last refresh: {last_refresh}.")
        if expiry:
            detail_bits.append(f"Access token expiry: {expiry}.")
        elif refresh_token:
            detail_bits.append("Refresh token is present.")
        return PASS, " ".join(detail_bits)

    return FAIL, "No usable API key or saved auth tokens found in ~/.codex/auth.json."


def load_optional_home_config(path: Path) -> dict[str, Any] | None:
    if not path.exists():
        return None
    loaded = load_toml(path)
    return loaded if isinstance(loaded, dict) else None


def resolve_runner_root_from_inputs(
    runner_root_arg: str | None,
    home_config_path: str,
) -> tuple[Path | None, str, dict[str, Any] | None]:
    home_config = load_optional_home_config(Path(home_config_path).expanduser())
    dummy_args = argparse.Namespace(runner_root=runner_root_arg, home_config=home_config_path)
    runner_root, source = detect_runner_root(dummy_args, home_config)
    return runner_root, source, home_config


def require_runner_root(runner_root_arg: str | None, home_config_path: str) -> Path:
    runner_root, _source, _home_config = resolve_runner_root_from_inputs(runner_root_arg, home_config_path)
    if runner_root is None:
        raise SystemExit(
            "Could not determine the runner root. Set CONTINUUM_RUNNER_ROOT, create ~/.config/continuum/config.toml, or pass --runner-root."
        )
    return runner_root.expanduser()


def resolve_projects_config_path(config_arg: str | None, runner_root: Path) -> Path:
    if config_arg:
        return Path(config_arg).expanduser()
    return runner_root / "projects.json"


def require_existing_path(path: Path, label: str) -> Path:
    if not path.exists():
        raise SystemExit(f"{label} does not exist: {path}")
    return path


def slugify_project_name(name: str) -> str:
    slug = re.sub(r"[^A-Za-z0-9._-]+", "_", name).strip("_")
    return slug or "project"


def pid_is_alive(pid: int | None) -> bool:
    if pid is None or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True


def read_pid(pid_path: Path) -> int | None:
    if not pid_path.exists():
        return None
    try:
        raw = pid_path.read_text(encoding="utf-8").strip()
        return int(raw) if raw else None
    except Exception:
        return None


def parse_dt(raw: str | None) -> datetime | None:
    if not raw:
        return None
    try:
        return datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except Exception:
        return None


def humanize_age(raw: str | None) -> str | None:
    dt = parse_dt(raw)
    if dt is None:
        return None
    now = datetime.now(timezone.utc)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    delta = max(0, int((now - dt.astimezone(timezone.utc)).total_seconds()))
    if delta < 60:
        return f"{delta}s ago"
    if delta < 3600:
        return f"{delta // 60}m ago"
    if delta < 86400:
        return f"{delta // 3600}h ago"
    return f"{delta // 86400}d ago"


def derive_overall_status(row: dict[str, Any]) -> str:
    restart_phase = row.get("restart_phase")
    if restart_phase:
        return f"restart:{restart_phase}"

    control_action = row.get("control_action")
    control_phase = row.get("control_phase")
    if control_action == "pause_after_pass" and control_phase:
        return f"pause:{control_phase}"

    state_kind = row.get("state_kind")
    supervisor_running = bool(row.get("supervisor_running"))
    if state_kind == "running":
        return "running" if supervisor_running else "stale"
    if state_kind == "inactive":
        return "inactive" if supervisor_running else "stale"
    if state_kind == "rate_limited_wait":
        return "waiting" if supervisor_running else "stale"
    if state_kind == "paused":
        return "paused"
    if state_kind == "stopped":
        return "stopped"
    if state_kind == "force_stopped":
        return "force-stopped"
    if state_kind == "done":
        return "done"
    if state_kind == "blocked":
        return "blocked"
    if state_kind == "failed":
        return "failed"
    if state_kind == "max_passes":
        return "max-passes"

    last_status = row.get("last_status")
    if supervisor_running:
        return "running"
    if last_status == "DONE":
        return "done"
    if last_status == "BLOCKED":
        return "blocked"
    if last_status == "FAILED":
        return "failed"
    if last_status == "RATE_LIMIT_WAIT":
        return "waiting"
    if row.get("enabled") is False:
        return "disabled"
    if row.get("updated_at"):
        return "idle"
    return "not-started"


def resolve_runtime_root(config_path: Path, payload: dict[str, Any]) -> Path:
    runtime_root = Path(str(payload.get("supervisor_root", "./runtime"))).expanduser()
    if not runtime_root.is_absolute():
        runtime_root = (config_path.parent / runtime_root).resolve()
    return runtime_root


def invoke_subprocess(cmd: list[str]) -> int:
    completed = subprocess.run(cmd, check=False)
    return completed.returncode


def require_runner_script(runner_root: Path, name: str) -> Path:
    script_path = runner_root / name
    if not script_path.exists():
        raise SystemExit(
            f"Runner script not found at {script_path}. Run `./continuum init` or repair the runner root first."
        )
    return script_path


def run_capture(cmd: list[str]) -> tuple[int, str]:
    completed = subprocess.run(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        encoding="utf-8",
        errors="replace",
        check=False,
    )
    return completed.returncode, completed.stdout


def load_projects_payload(config_path: Path) -> tuple[dict[str, Any], list[dict[str, Any]]]:
    payload = load_json(config_path)
    if not isinstance(payload, dict):
        raise SystemExit(f"projects.json must contain an object at top level: {config_path}")

    projects = payload.get("projects", [])
    if not isinstance(projects, list):
        raise SystemExit(f"'projects' must be a list in {config_path}")

    normalized: list[dict[str, Any]] = [item for item in projects if isinstance(item, dict)]
    return payload, normalized


def find_project_entry(config_path: Path, project_name: str) -> tuple[dict[str, Any], dict[str, Any]]:
    payload, projects = load_projects_payload(config_path)
    for item in projects:
        if str(item.get("name")) == project_name:
            return payload, item
    raise SystemExit(f"Project not found in {config_path}: {project_name}")


def ensure_runner_scripts_current(runner_root: Path) -> None:
    sync_runner_scripts(runner_root, force=False)


def detect_service_manager() -> str:
    if sys.platform == "darwin":
        if shutil.which("launchctl") is None:
            raise SystemExit("launchctl is not available on this macOS host.")
        return "launchctl"
    if sys.platform.startswith("linux"):
        if shutil.which("systemctl") is None:
            raise SystemExit("systemctl is not available on this Linux host.")
        return "systemd"
    raise SystemExit("Continuum service mode currently supports macOS launchctl and Linux systemd --user.")


def default_service_dir(manager: str) -> Path:
    if manager == "launchctl":
        return Path("~/Library/LaunchAgents").expanduser()
    if manager == "systemd":
        return Path("~/.config/systemd/user").expanduser()
    raise SystemExit(f"Unsupported service manager: {manager}")


def service_timeout_seconds() -> int:
    raw = os.environ.get("CONTINUUM_SERVICE_STOP_TIMEOUT_SECONDS", "")
    if raw.isdigit():
        return int(raw)
    return DEFAULT_SERVICE_TIMEOUT_SECONDS


def build_service_metadata(
    runner_root: Path,
    config_path: Path,
    project_name: str,
    service_dir_arg: str | None,
    require_service_runner: bool = True,
) -> dict[str, Any]:
    _payload, project = find_project_entry(config_path, project_name)
    manager = detect_service_manager()
    slug = slugify_project_name(project_name)
    runner_root = runner_root.expanduser().resolve()
    config_path = config_path.expanduser().resolve()
    python_path = Path(sys.executable).resolve()
    service_runner = runner_root / "service_runner.py"
    if require_service_runner:
        service_runner = require_runner_script(runner_root, "service_runner.py")
    service_dir = Path(service_dir_arg).expanduser().resolve() if service_dir_arg else default_service_dir(manager)
    timeout = service_timeout_seconds()

    if manager == "launchctl":
        name = f"{SERVICE_LABEL_PREFIX}.{slug}"
        install_path = service_dir / f"{name}.plist"
        service_target = f"gui/{os.getuid()}/{name}"
    else:
        name = f"continuum-{slug}.service"
        install_path = service_dir / name
        service_target = name

    return {
        "manager": manager,
        "project_name": project_name,
        "project_path": str(project.get("path", "")),
        "slug": slug,
        "label": name,
        "service_target": service_target,
        "service_dir": service_dir,
        "install_path": install_path,
        "python_path": python_path,
        "runner_root": runner_root,
        "config_path": config_path,
        "service_runner": service_runner,
        "log_path": runner_root / f"service.{slug}.log",
        "supervisor_pidfile": runner_root / f"supervisor.{slug}.pid",
        "timeout_seconds": timeout,
    }


def render_launchd_plist(meta: dict[str, Any]) -> str:
    program_args = [
        str(meta["python_path"]),
        str(meta["service_runner"]),
        str(meta["config_path"]),
        str(meta["project_name"]),
    ]
    args_xml = "\n".join(f"      <string>{xml_escape(arg)}</string>" for arg in program_args)
    return f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>{xml_escape(str(meta["label"]))}</string>
    <key>ProgramArguments</key>
    <array>
{args_xml}
    </array>
    <key>WorkingDirectory</key>
    <string>{xml_escape(str(meta["runner_root"]))}</string>
    <key>ProcessType</key>
    <string>Background</string>
    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <false/>
    <key>ExitTimeOut</key>
    <integer>{int(meta["timeout_seconds"])}</integer>
    <key>StandardOutPath</key>
    <string>{xml_escape(str(meta["log_path"]))}</string>
    <key>StandardErrorPath</key>
    <string>{xml_escape(str(meta["log_path"]))}</string>
  </dict>
</plist>
"""


def render_systemd_unit(meta: dict[str, Any]) -> str:
    exec_start = shlex.join(
        [
            str(meta["python_path"]),
            str(meta["service_runner"]),
            str(meta["config_path"]),
            str(meta["project_name"]),
        ]
    )
    return f"""[Unit]
Description=Continuum for Codex ({meta["project_name"]})
After=default.target

[Service]
Type=simple
WorkingDirectory={meta["runner_root"]}
ExecStart={exec_start}
KillSignal=SIGTERM
TimeoutStopSec={int(meta["timeout_seconds"])}
Restart=no
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
"""


def ensure_launchd_loaded(meta: dict[str, Any]) -> None:
    rc, _output = run_capture(["launchctl", "print", meta["service_target"]])
    if rc == 0:
        return
    rc, output = run_capture(["launchctl", "bootstrap", f"gui/{os.getuid()}", str(meta["install_path"])])
    if rc != 0:
        raise SystemExit(output.strip() or f"Failed to bootstrap {meta['install_path']}")


def parse_launchctl_pid(output: str) -> int | None:
    match = re.search(r"\bpid = (\d+)\b", output)
    if not match:
        return None
    try:
        return int(match.group(1))
    except ValueError:
        return None


def collect_service_status(meta: dict[str, Any]) -> dict[str, Any]:
    installed = Path(meta["install_path"]).exists()
    result: dict[str, Any] = {
        "project_name": meta["project_name"],
        "manager": meta["manager"],
        "install_path": str(meta["install_path"]),
        "service_target": str(meta["service_target"]),
        "installed": installed,
        "loaded": False,
        "active": False,
        "service_pid": None,
        "supervisor_pid": read_pid(Path(meta["supervisor_pidfile"])),
        "supervisor_running": False,
    }

    if meta["manager"] == "launchctl":
        rc, output = run_capture(["launchctl", "print", meta["service_target"]])
        result["loaded"] = rc == 0
        result["raw_status"] = output.strip()
        result["service_pid"] = parse_launchctl_pid(output) if rc == 0 else None
        result["active"] = pid_is_alive(result["service_pid"]) if isinstance(result["service_pid"], int) else False
    else:
        cmd = [
            "systemctl",
            "--user",
            "show",
            str(meta["service_target"]),
            "--property",
            "LoadState",
            "--property",
            "ActiveState",
            "--property",
            "SubState",
            "--property",
            "MainPID",
            "--property",
            "UnitFileState",
        ]
        rc, output = run_capture(cmd)
        fields: dict[str, str] = {}
        if rc == 0:
            for line in output.splitlines():
                if "=" not in line:
                    continue
                key, value = line.split("=", 1)
                fields[key] = value
        result["fields"] = fields
        result["loaded"] = fields.get("LoadState") == "loaded"
        result["active"] = fields.get("ActiveState") == "active"
        main_pid = fields.get("MainPID")
        if main_pid and main_pid.isdigit() and int(main_pid) > 0:
            result["service_pid"] = int(main_pid)
        result["raw_status"] = output.strip()

    supervisor_pid = result.get("supervisor_pid")
    result["supervisor_running"] = pid_is_alive(supervisor_pid if isinstance(supervisor_pid, int) else None)
    return result


def wait_for_pid_exit(pid: int | None, timeout_seconds: int) -> bool:
    if pid is None:
        return True
    deadline = datetime.now(timezone.utc).timestamp() + max(timeout_seconds, 0)
    while pid_is_alive(pid):
        if datetime.now(timezone.utc).timestamp() >= deadline:
            return False
        time.sleep(2)
    return True


def sync_runner_scripts(runner_root: Path, force: bool) -> tuple[list[str], list[str]]:
    source_root = Path(__file__).resolve().parent / "supervisor"
    copied: list[str] = []
    skipped: list[str] = []
    runner_root.mkdir(parents=True, exist_ok=True)

    for src in sorted(source_root.iterdir()):
        if not src.is_file():
            continue
        if src.name == "projects.example.json":
            dst = runner_root / "projects.json"
            if dst.exists():
                skipped.append(dst.name)
                continue
            payload = load_json(src)
            if isinstance(payload, dict):
                payload["projects"] = []
                dst.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
            else:
                shutil.copy2(src, dst)
            copied.append(dst.name)
            continue

        dst = runner_root / src.name
        if dst.exists() and not force:
            skipped.append(dst.name)
            continue
        shutil.copy2(src, dst)
        dst.chmod(dst.stat().st_mode | 0o111)
        copied.append(dst.name)

    return copied, skipped


def run_init(args: argparse.Namespace) -> int:
    runner_root, _source, _home_config = resolve_runner_root_from_inputs(args.runner_root, args.home_config)
    if runner_root is None:
        runner_root = Path(args.home_runner_link).expanduser()
    runner_root = runner_root.expanduser()

    copied, skipped = sync_runner_scripts(runner_root, args.force)

    install_cmd = [
        sys.executable,
        str(Path(__file__).resolve().parent / "scripts" / "install_home.py"),
        "--runner-root",
        str(runner_root),
        "--kit-root",
        str(Path(__file__).resolve().parent),
        "--config-path",
        args.home_config,
        "--home-runner-link",
        args.home_runner_link,
    ]
    if args.force:
        install_cmd.append("--force")

    rc = invoke_subprocess(install_cmd)
    if rc != 0:
        return rc

    print()
    print(f"Runner root: {runner_root}")
    if copied:
        print("Copied:", ", ".join(copied))
    if skipped:
