def run_service_install(args: argparse.Namespace) -> int:
    runner_root = require_runner_root(args.runner_root, args.home_config)
    ensure_runner_scripts_current(runner_root)
    config_path = require_existing_path(resolve_projects_config_path(args.config, runner_root), "Config file")
    meta = build_service_metadata(runner_root, config_path, args.project_name, args.service_dir)
    meta["service_dir"].mkdir(parents=True, exist_ok=True)

    if meta["manager"] == "launchctl":
        content = render_launchd_plist(meta)
    else:
        content = render_systemd_unit(meta)
    Path(meta["install_path"]).write_text(content, encoding="utf-8")

    if args.no_manager:
        print(f"Wrote service definition: {meta['install_path']}")
        return 0

    if meta["manager"] == "launchctl":
        run_capture(["launchctl", "bootout", f"gui/{os.getuid()}", str(meta["install_path"])])
        ensure_launchd_loaded(meta)
    else:
        rc, output = run_capture(["systemctl", "--user", "daemon-reload"])
        if rc != 0:
            raise SystemExit(output.strip() or "systemctl --user daemon-reload failed")

    print(f"Installed service definition for {args.project_name}: {meta['install_path']}")
    return 0


def run_service_uninstall(args: argparse.Namespace) -> int:
    runner_root = require_runner_root(args.runner_root, args.home_config)
    config_path = require_existing_path(resolve_projects_config_path(args.config, runner_root), "Config file")
    meta = build_service_metadata(runner_root, config_path, args.project_name, args.service_dir, require_service_runner=False)

    if not args.no_manager:
        if meta["manager"] == "launchctl":
            run_capture(["launchctl", "bootout", f"gui/{os.getuid()}", str(meta["install_path"])])
            Path(meta["install_path"]).unlink(missing_ok=True)
        else:
            run_capture(["systemctl", "--user", "disable", "--now", str(meta["service_target"])])
            Path(meta["install_path"]).unlink(missing_ok=True)
            rc, output = run_capture(["systemctl", "--user", "daemon-reload"])
            if rc != 0:
                raise SystemExit(output.strip() or "systemctl --user daemon-reload failed")
    else:
        Path(meta["install_path"]).unlink(missing_ok=True)
    print(f"Removed service definition for {args.project_name}: {meta['install_path']}")
    return 0


def run_service_start(args: argparse.Namespace) -> int:
    runner_root = require_runner_root(args.runner_root, args.home_config)
    ensure_runner_scripts_current(runner_root)
    config_path = require_existing_path(resolve_projects_config_path(args.config, runner_root), "Config file")
    meta = build_service_metadata(runner_root, config_path, args.project_name, args.service_dir)

    if not Path(meta["install_path"]).exists():
        install_args = argparse.Namespace(
            project_name=args.project_name,
            runner_root=args.runner_root,
            home_config=args.home_config,
            config=str(config_path),
            service_dir=args.service_dir,
            no_manager=False,
        )
        run_service_install(install_args)

    if meta["manager"] == "launchctl":
        ensure_launchd_loaded(meta)
        rc, output = run_capture(["launchctl", "kickstart", "-p", str(meta["service_target"])])
        if rc != 0:
            raise SystemExit(output.strip() or f"Failed to start service {meta['service_target']}")
    else:
        rc, output = run_capture(["systemctl", "--user", "start", str(meta["service_target"])])
        if rc != 0:
            raise SystemExit(output.strip() or f"Failed to start service {meta['service_target']}")

    print(f"Started service for {args.project_name}")
    return 0


def run_service_stop(args: argparse.Namespace) -> int:
    runner_root = require_runner_root(args.runner_root, args.home_config)
    config_path = require_existing_path(resolve_projects_config_path(args.config, runner_root), "Config file")
    meta = build_service_metadata(runner_root, config_path, args.project_name, args.service_dir)

    if meta["manager"] == "launchctl":
        rc, output = run_capture(["launchctl", "kill", "TERM", str(meta["service_target"])])
        if rc != 0:
            pid = read_pid(Path(meta["supervisor_pidfile"]))
            if pid is not None and pid_is_alive(pid):
                os.kill(pid, signal.SIGTERM)
            elif output.strip():
                raise SystemExit(output.strip())
    else:
        rc, output = run_capture(["systemctl", "--user", "stop", str(meta["service_target"])])
        if rc != 0:
            raise SystemExit(output.strip() or f"Failed to stop service {meta['service_target']}")

    print(f"Requested clean stop for service {args.project_name}")
    return 0


def run_service_restart(args: argparse.Namespace) -> int:
    runner_root = require_runner_root(args.runner_root, args.home_config)
    ensure_runner_scripts_current(runner_root)
    config_path = require_existing_path(resolve_projects_config_path(args.config, runner_root), "Config file")
    meta = build_service_metadata(runner_root, config_path, args.project_name, args.service_dir)

    if not Path(meta["install_path"]).exists():
        install_args = argparse.Namespace(
            project_name=args.project_name,
            runner_root=args.runner_root,
            home_config=args.home_config,
            config=str(config_path),
            service_dir=args.service_dir,
            no_manager=False,
        )
        run_service_install(install_args)

    if meta["manager"] == "launchctl":
        status = collect_service_status(meta)
        pid = status.get("supervisor_pid")
        if not isinstance(pid, int) or not pid_is_alive(pid):
            ensure_launchd_loaded(meta)
            rc, output = run_capture(["launchctl", "kickstart", "-p", str(meta["service_target"])])
            if rc != 0:
                raise SystemExit(output.strip() or f"Failed to start service {meta['service_target']}")
            print(f"Started service for {args.project_name}")
            return 0

        rc, output = run_capture(["launchctl", "kill", "TERM", str(meta["service_target"])])
        if rc != 0:
            raise SystemExit(output.strip() or f"Failed to signal service {meta['service_target']}")
        if not wait_for_pid_exit(pid, int(meta["timeout_seconds"])):
            raise SystemExit(
                f"Timed out waiting for {args.project_name} to exit cleanly after {meta['timeout_seconds']} seconds."
            )
        rc, output = run_capture(["launchctl", "kickstart", "-p", str(meta["service_target"])])
        if rc != 0:
            raise SystemExit(output.strip() or f"Failed to restart service {meta['service_target']}")
    else:
        rc, output = run_capture(["systemctl", "--user", "restart", str(meta["service_target"])])
        if rc != 0:
            raise SystemExit(output.strip() or f"Failed to restart service {meta['service_target']}")

    print(f"Restarted service for {args.project_name}")
    return 0


